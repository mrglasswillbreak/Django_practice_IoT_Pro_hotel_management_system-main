# Receptionist login managed from environment variables
DEFAULT_RECEPTIONIST_EMAIL=receptionist@hotel.com
DEFAULT_RECEPTIONIST_PASSWORD=FrontDesk123!
DEFAULT_RECEPTIONIST_FIRST_NAME=Front
DEFAULT_RECEPTIONIST_LAST_NAME=Desk
DEFAULT_RECEPTIONIST_PHONE=+2348012345678
DEFAULT_RECEPTIONIST_THEME=light
DEFAULT_RECEPTIONIST_IS_ACTIVE=true
DEFAULT_RECEPTIONIST_SYNC_PASSWORD=true

# Email delivery for account confirmation
# Leave these unset in local development to show the activation link on-screen.
# Set them in production (or locally) to send real confirmation emails.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=noreply@yourhotel.com
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@yourhotel.com
# EMAIL_HOST_PASSWORD=replace-with-email-password
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false
